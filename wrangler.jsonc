{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "fork-or-profit",
  "compatibility_date": "2025-08-03",
  "main": "./src/worker.ts",
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "fork-or-profit-db",
      "database_id": "c656cf31-da55-47b1-8d9b-2a149ab0713f"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "e19299b1bd044c79964a5715dee7aa0e"
    }
  ]
}
